<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ContactListMVVM.Views.Homepage"
			 xmlns:vm="clr-namespace:ContactListMVVM.Models.ViewModels"
				x:DataType="vm:ContactListViewModel"
             Title="Home Page">
	<ScrollView>
		<VerticalStackLayout Spacing="15" Padding="20">

			<Label Text="Create a Contact" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" Margin="0,0,0,20"/>

			<Entry x:Name="Name" Text="{Binding Contact.Name}" Placeholder="Full Name" />
			<Entry x:Name="Email" Text="{Binding Contact.Email}" Placeholder="Email Address" Keyboard="Email" />
			<Entry x:Name="PhoneNumber" Text="{Binding Contact.PhoneNumber}" Placeholder="Phone Number" Keyboard="Telephone" />
			<Entry x:Name="Description" Text="{Binding Contact.Description}" Placeholder="Description" />


			<Button x:Name="addButton" Text="Add Contact" Command="{Binding AddCommand}"/>
			<Button Text="View Contacts" Clicked="Button_Clicked"/>


		</VerticalStackLayout>
	</ScrollView>
</ContentPage>