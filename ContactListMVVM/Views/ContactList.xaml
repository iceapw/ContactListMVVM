<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ContactListMVVM.Views.ContactList"
             xmlns:vm="clr-namespace:ContactListMVVM.Models.ViewModels"
             xmlns:models="clr-namespace:ContactListMVVM.Models"
             x:DataType="vm:ContactListViewModel"
             Title="Contacts">
	<VerticalStackLayout Spacing="15" Padding="20">

		<ListView x:Name="Lv"
                  ItemsSource="{Binding Contacts}"
                  ItemTapped="Lv_ItemTapped">
			<ListView.Header>
				<VerticalStackLayout  Padding="5">
					<Label Text="Contacts"
						   FontSize="24"
                           HorizontalOptions="Center"
                           FontAttributes="Bold"/>
				</VerticalStackLayout>
			</ListView.Header>
			<ListView.ItemTemplate>
				<DataTemplate x:DataType="{x:Type models:Contacts}">
					<TextCell Text="{Binding Name}"
                              Detail="{Binding Email}"/>
				</DataTemplate>
			</ListView.ItemTemplate>
		</ListView>

	</VerticalStackLayout>
</ContentPage>