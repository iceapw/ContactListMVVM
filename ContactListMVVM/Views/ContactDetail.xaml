<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ContactListMVVM.Models.ViewModels"
             x:DataType="vm:ContactDetailViewModel"
             x:Class="ContactListMVVM.Views.ContactDetail"
             Title="Contact Details">
	<ScrollView>
		<VerticalStackLayout Spacing="15" Padding="20">
			<Label Text="Contact Details"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,0,0,20"/>
			<Label Text="Name" FontAttributes="Bold"/>
			<Label Text="{Binding Contact.Name}" />
			<Label Text="Email" FontAttributes="Bold"/>
			<Label Text="{Binding Contact.Email}" />
			<Label Text="Phone Number" FontAttributes="Bold"/>
			<Label Text="{Binding Contact.PhoneNumber}" />
			<Label Text="Description" FontAttributes="Bold"/>
			<Label Text="{Binding Contact.Description}" />
			<Button Text="Back" Clicked="OnBackClicked" />
		</VerticalStackLayout>
	</ScrollView>
</ContentPage>